# Install aichat - AI-powered chat CLI
# https://github.com/sigoden/aichat
AICHAT_VERSION="0.30.0"

if ! _which aichat; then
  if echo "$OSTYPE" | grep -i darwin > /dev/null; then
    mkdir -p "${HOME}/.local/bin"
    AICHAT_ARCH="$(uname -m)"
    [ "$AICHAT_ARCH" = "arm64" ] && AICHAT_ARCH="aarch64"
    curl -fsSL "https://github.com/sigoden/aichat/releases/download/v${AICHAT_VERSION}/aichat-v${AICHAT_VERSION}-${AICHAT_ARCH}-apple-darwin.tar.gz" -o "/tmp/aichat.tar.gz"
    tar -xzf /tmp/aichat.tar.gz -C "${HOME}/.local/bin" aichat
  else
    curl -fsSL "https://github.com/sigoden/aichat/releases/download/v${AICHAT_VERSION}/aichat-v${AICHAT_VERSION}-x86_64-unknown-linux-musl.tar.gz" -o "/tmp/aichat.tar.gz"
    eval "$SUDO tar -xzf /tmp/aichat.tar.gz -C /usr/local/bin/ aichat"
  fi
  rm -f /tmp/aichat.tar.gz
fi
