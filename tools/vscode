# VS Code wrapper for WSL2 - calls Windows VS Code directly
# without adding Windows paths to PATH (avoids WSL PATH latency)
if [ -d "/mnt/c" ] && ! _which code; then
  VSCODE_PATH="/mnt/c/Users/benja/AppData/Local/Programs/Microsoft VS Code/bin/code"
  if [ -f "$VSCODE_PATH" ]; then
    code() {
      "$VSCODE_PATH" "$@"
    }
  fi
elif echo "$OSTYPE" | grep -i darwin > /dev/null && ! _which code; then
  if [ -d "/Applications/Visual Studio Code.app" ]; then
    code() {
      open -a "Visual Studio Code" "$@"
    }
  elif _which brew; then
    brew_cask_install visual-studio-code
  fi
fi
