#! /usr/bin/env bash

if echo $OSTYPE | grep -i linux > /dev/null; then

  ensure_xterm_ghostty_terminfo () {
    if infocmp -x xterm-ghostty > /dev/null 2>&1; then
      return 0
    fi

    apt_get_install ncurses-bin tic

    if infocmp -x xterm-ghostty > /dev/null 2>&1; then
      return 0
    fi

    if _which curl && _which tic; then
      local terminfo_url="https://raw.githubusercontent.com/ghostty-org/ghostty/main/terminfo/xterm-ghostty"
      local terminfo_file="/tmp/xterm-ghostty.terminfo"

      if curl -fsSL "${terminfo_url}" -o "${terminfo_file}"; then
        mkdir -p "${HOME}/.terminfo"
        tic -x -o "${HOME}/.terminfo" "${terminfo_file}" > /dev/null 2>&1 || true
        rm -f "${terminfo_file}"
      fi
    fi

    if ! infocmp -x xterm-ghostty > /dev/null 2>&1 \
    && [ "${TERM:-}" = "xterm-ghostty" ]; then
      export TERM=xterm-256color
    fi
  }

  apt_get_install apt-utils apt-extracttemplates
  apt_get_install locales update-locale
  apt_get_install bsdmainutils column
  apt_get_install unzip
  apt_get_install git
  apt_get_install curl
  apt_get_install xsel
  apt_get_install sudo
  apt_get_install wget
  apt_get_install tmux
  apt_get_install openvpn
  apt_get_install traceroute
  apt_get_install nmap
  apt_get_install strace
  apt_get_install jq
  ensure_xterm_ghostty_terminfo
  unset -f ensure_xterm_ghostty_terminfo
  apt_get_install silversearcher-ag ag
  # Needed for coc-lua lsp server vim plugin
  # Link: https://stackoverflow.com/questions/20079572/srlua-makefile-error-lua-h-no-such-file-or-directory/20080097
  apt_get_install "lua5.3" lua
  apt_get_install "liblua5.3-dev" lua

  if [ ! -f "/usr/bin/lua" ] \
  && [ -f "/usr/bin/lua5.3" ]; then
    ln -s "/usr/bin/lua5.3" "/usr/bin/lua"
  fi
  # These two collide right now so this is temporary.  See issue below
  # apt_get_install bat batcat
  # apt_get_install ripgrep rg
  # Fixing Bug: https://github.com/sharkdp/bat/issues/938#issuecomment-646745610
  if (! _which batcat && ! _which bat) \
  || ! _which rg; then
    eval "$SUDO apt-get install -o Dpkg::Options::='--force-overwrite' -y bat ripgrep"
  fi

  # AWS CLI v2
  if ! _which aws; then
    curl -s "https://awscli.amazonaws.com/awscli-exe-linux-x86_64.zip" -o "/tmp/awscliv2.zip"
    unzip -qo /tmp/awscliv2.zip -d /tmp
    eval "$SUDO /tmp/aws/install"
    rm -rf /tmp/awscliv2.zip /tmp/aws
  fi
elif echo "$OSTYPE" | grep -i darwin > /dev/null; then
  if _which brew; then
    brew_install git
    brew_install curl
    brew_install wget
    brew_install tmux
    brew_install openvpn
    brew_install nmap
    brew_install jq
    brew_install the_silver_searcher ag
    brew_install lua
    brew_install unzip
    brew_install ripgrep rg
    brew_install bat
    brew_install awscli aws
  else
    echo "Homebrew not found. Skipping macOS package installs from install-tools."
    mkdir -p "${HOME}/.local/bin"

    if ! _which rg; then
      RG_ARCH="$(uname -m)"
      [ "$RG_ARCH" = "arm64" ] && RG_ARCH="aarch64"
      RG_TAG="$(curl -fsSL https://api.github.com/repos/BurntSushi/ripgrep/releases/latest | sed -nE 's/.*"tag_name": *"([^"]+)".*/\1/p' | head -1)"
      RG_VERSION="${RG_TAG#v}"
      if [ -n "$RG_VERSION" ]; then
        RG_PACKAGE="ripgrep-${RG_VERSION}-${RG_ARCH}-apple-darwin"
        curl -fsSL "https://github.com/BurntSushi/ripgrep/releases/download/${RG_TAG}/${RG_PACKAGE}.tar.gz" -o "/tmp/${RG_PACKAGE}.tar.gz"
        tar -xzf "/tmp/${RG_PACKAGE}.tar.gz" -C /tmp
        cp "/tmp/${RG_PACKAGE}/rg" "${HOME}/.local/bin/rg"
        rm -rf "/tmp/${RG_PACKAGE}" "/tmp/${RG_PACKAGE}.tar.gz"
      fi
    fi

    if ! _which bat; then
      BAT_ARCH="$(uname -m)"
      [ "$BAT_ARCH" = "arm64" ] && BAT_ARCH="aarch64"
      BAT_TAG="$(curl -fsSL https://api.github.com/repos/sharkdp/bat/releases/latest | sed -nE 's/.*"tag_name": *"([^"]+)".*/\1/p' | head -1)"
      BAT_VERSION="${BAT_TAG#v}"
      if [ -n "$BAT_VERSION" ]; then
        BAT_PACKAGE="bat-v${BAT_VERSION}-${BAT_ARCH}-apple-darwin"
        curl -fsSL "https://github.com/sharkdp/bat/releases/download/${BAT_TAG}/${BAT_PACKAGE}.tar.gz" -o "/tmp/${BAT_PACKAGE}.tar.gz"
        tar -xzf "/tmp/${BAT_PACKAGE}.tar.gz" -C /tmp
        cp "/tmp/${BAT_PACKAGE}/bat" "${HOME}/.local/bin/bat"
        rm -rf "/tmp/${BAT_PACKAGE}" "/tmp/${BAT_PACKAGE}.tar.gz"
      fi
    fi
  fi
fi

# Ensure tools directory exists
mkdir -p "$HOME/run/tools"

# List of tools to load if missing from cache
for tool in "${BENVIRONMENT_TOOLS_LIST[@]}"; do
  TOOL_CACHE="${HOME}/run/tools/${tool}"
  TOOL_SOURCE="${HOME}/reverts/benvironment/tools/${tool}"
  if [ -f "${TOOL_SOURCE}" ]; then
    cp "${TOOL_SOURCE}" "${TOOL_CACHE}"
    chmod +x "${TOOL_CACHE}"
  elif [ ! -f "${TOOL_CACHE}" ]; then
    if curl -s "${URL_PATH_TO_ENV_FILES}/tools/${tool}" -o "${TOOL_CACHE}" && [ -s "${TOOL_CACHE}" ]; then
      chmod +x "${TOOL_CACHE}"
    else
      echo "WARN: unable to load tool definition for ${tool}"
      continue
    fi
  fi

  [ -f "${TOOL_CACHE}" ] && source "${TOOL_CACHE}"
done

if type rg &> /dev/null; then
  export FZF_DEFAULT_COMMAND='rg --files'
  export FZF_DEFAULT_OPTS='-m --height 50% --border'
fi

#############################################################################
# Global Configs
#############################################################################
# If bat successfully gets installed we will
# swap cat with bat
if _which batcat; then
  alias cat='batcat'
elif _which bat; then
  alias cat='bat'
fi

if _which prettyping; then
  alias ping='prettyping --nolegend'
fi

if _which locale-gen \
&& ! grep 'en_US.UTF-8' /etc/default/locale > /dev/null;
then
  eval "$SUDO locale-gen 'en_US.UTF-8'"
  eval "$SUDO update-locale LC_ALL=en_US.UTF-8 LANG=en_US.UTF-8"
fi

if [ ! -f "$HOME/.gitconfig" ]; then
  userEmail="$(dec_value GIT_EMAIL)"
  if [ $? -eq 0 ]; then
    git config --global user.email "$userEmail"
    git config --global user.name "Benjamin Hudgens"
  fi
fi
