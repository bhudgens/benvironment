#!/usr/bin/env bash
#############################################################################
# AI Tool Config Management
#
# Installs portable global configs for: claude-code, codex, opencode
# from ~/.dotfiles into their expected locations, using the same
# install_dot_file / install_dot_dir pattern as the rest of benvironment.
#
# To persist a change across all machines:
#   1. Edit the file under ~/reverts/dotfiles/
#   2. Commit and push from ~/reverts/dotfiles
#   On next shell load, all machines pull and pick up the update.
#
# Managed:
#   ~/.claude/CLAUDE.md         <- ~/.dotfiles/.claude/CLAUDE.md
#   ~/.claude/settings.json     <- ~/.dotfiles/.claude/settings.json
#   ~/.claude/commands/         <- ~/.dotfiles/.claude/commands/
#   ~/.claude/skills/           <- ~/.dotfiles/.claude/skills/
#   ~/.codex/AGENTS.md          <- ~/.dotfiles/.codex/AGENTS.md
#   ~/.opencode/AGENTS.md       <- ~/.dotfiles/.opencode/AGENTS.md
#############################################################################

# Claude Code
install_dot_file ".claude/CLAUDE.md"
install_dot_file ".claude/settings.json"
install_dot_dir  ".claude/commands"
install_dot_dir  ".claude/skills"

# Codex
install_dot_file ".codex/AGENTS.md"

# OpenCode
install_dot_file ".opencode/AGENTS.md"
