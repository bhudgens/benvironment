#!/usr/bin/env bash
#############################################################################
# AI Tool Config Management
#
# benvironment loads this module, but the AI assistant config source of truth
# lives in ~/reverts/ai. Dotfiles remains responsible for shell/tmux/zsh files.
#
# Managed by ~/reverts/ai/install.sh:
#   ~/.claude/CLAUDE.md
#   ~/.claude/settings.json
#   ~/.claude/skills/
#   ~/.codex/AGENTS.md
#   ~/.codex/skills/
#   ~/.opencode/AGENTS.md
#   ~/.config/opencode/commands/
#############################################################################

AI_TOOLS_REPO="${AI_TOOLS_REPO:-${HOME}/reverts/ai}"

_ai_tools_needs_bootstrap() {
  [ ! -f "${HOME}/.codex/AGENTS.md" ] \
  || [ ! -f "${HOME}/.claude/CLAUDE.md" ] \
  || [ ! -f "${HOME}/.claude/settings.json" ] \
  || [ ! -f "${HOME}/.opencode/AGENTS.md" ] \
  || [ ! -d "${HOME}/.claude/skills" ] \
  || [ ! -d "${HOME}/.codex/skills" ] \
  || [ ! -d "${HOME}/.config/opencode/commands" ]
}

if [ -f "${AI_TOOLS_REPO}/install.sh" ] && _ai_tools_needs_bootstrap; then
  if [ -x "${AI_TOOLS_REPO}/install.sh" ]; then
    "${AI_TOOLS_REPO}/install.sh"
  else
    bash "${AI_TOOLS_REPO}/install.sh"
  fi
fi

unset -f _ai_tools_needs_bootstrap
